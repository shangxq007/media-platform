    { "assetId": "moving_box_1080p", "type": "video", "path": "assets/video/moving_box_1080p.mp4", "expectedDurationMs": 10000, "expectedWidth": 1920, "expectedHeight": 1080, "purpose": "Blur region / tracking reference" },
