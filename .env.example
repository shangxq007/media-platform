# Local Development Environment Variables
# Copy this file to .env and adjust values as needed.
# NEVER commit .env to version control.

# Database
POSTGRES_DB=platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=change-me-in-local-env
POSTGRES_PORT=5432

# Application
APP_PORT=8080
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/platform
SPRING_DATASOURCE_USERNAME=platform
SPRING_DATASOURCE_PASSWORD=change-me-in-local-env

# Storage
APP_STORAGE_LOCAL_ROOT=/data/storage

# AI Stub (development only)
APP_AI_STUB_ENABLE_FAILURES=false
APP_AI_STUB_FAILURE_RATE=0.0
APP_AI_STUB_MAX_RETRIES=3
APP_AI_STUB_RETRY_DELAY_MS=1000

# Feature Flags
APP_FEATURES_UNLEASH_ENABLED=false

# Render
RENDER_EXECUTION_MODE=local

# Outbox
APP_OUTBOX_DISPATCH_INTERVAL_MS=3000

# Observability
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus

# Secrets (examples only - use a real secret manager in production)
# DO NOT put real secrets here. Use .env (gitignored) or a vault.
# EXAMPLE_API_KEY=your-api-key-here
# EXAMPLE_SECRET=your-secret-here
